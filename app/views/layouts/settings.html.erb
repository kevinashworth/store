<%= content_for :content do %>
  <section class="settings">
    <nav class="settings-nav">
      <h3>Account Settings</h3>
      <div><%= link_to "Profile", settings_profile_path %></div>
      <div><%= link_to "Email", settings_email_path %></div>
      <div><%= link_to "Password", settings_password_path %></div>
      <div><%= link_to "Account", settings_user_path %></div>
    </nav>

    <div>
      <%= yield %>
    </div>
  </section>
<% end %>

<%= render template: "layouts/application" %>

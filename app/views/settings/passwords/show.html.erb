<h1>Password</h1>
<h2>This is the Settings namespace</h2>

<div class="max-w-md mt-8">
  <%= form_with model: Current.user, url: settings_password_path do |form| %>
    <div class="flex flex-col gap-4">
      <% if form.object.errors.any? %>
        <p class="error"><%= form.object.errors.full_messages.first %></p>
      <% end %>

      <div>
        <%= form.label :password_challenge, class: "block font-medium text-gray-900" %>
        <div class="flex items-center rounded-md bg-white outline-1 -outline-offset-1 outline-gray-300 focus-within:outline-2 focus-within:-outline-offset-2 focus-within:outline-green-600">
          <%= form.password_field :password_challenge, required: true, autocomplete: "current-password", class: "block min-w-0 grow bg-white p-2 text-base text-gray-900 focus:outline-none sm:text-sm/6" %>
        </div>
      </div>

      <div>
        <%= form.label :password, class: "block font-medium text-gray-900" %>
        <div class="flex items-center rounded-md bg-white outline-1 -outline-offset-1 outline-gray-300 focus-within:outline-2 focus-within:-outline-offset-2 focus-within:outline-green-600">
          <%= form.password_field :password, required: true, autocomplete: "new-password", class: "block min-w-0 grow bg-white p-2 text-base text-gray-900 focus:outline-none sm:text-sm/6"  %>
        </div>
      </div>

      <div>
        <%= form.label :password_confirmation, class: "block font-medium text-gray-900" %>
        <div class="flex items-center rounded-md bg-white outline-1 -outline-offset-1 outline-gray-300 focus-within:outline-2 focus-within:-outline-offset-2 focus-within:outline-green-600">
          <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", class: "block min-w-0 grow bg-white p-2 text-base text-gray-900 focus:outline-none sm:text-sm/6" %>
        </div>
      </div>

      <div class="mt-6 flex items-center justify-end gap-x-6">
        <%= form.submit "Update password", class: "rounded-md bg-green-600 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-green-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600" %>
      </div>
    </div>
  <% end %>
</div>